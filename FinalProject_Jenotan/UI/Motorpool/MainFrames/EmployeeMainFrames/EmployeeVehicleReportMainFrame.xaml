<Page x:Class="FinalProject_Jenotan.UI.Motorpool.MainFrames.EmployeeMainFrames.EmployeeVehicleReportMainFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FinalProject_Jenotan.UI.Motorpool.MainFrames.EmployeeMainFrames"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:cmd="clr-namespace:FinalProject_Jenotan.Commands"
              xmlns:converters="clr-namespace:FinalProject_Jenotan.Commands"
            Title="EmployeeVehicleReportMainFrame"
            Background="#f9dcdc">

    <Page.Resources>
        <cmd:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatussColorConverter"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:FacultyNameInitialConverter x:Key="FacultyNameInitialConverter"/>
        <converters:FacultyFullNameConverter x:Key="FacultyFullNameConverter"/>
    </Page.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="0.15*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="0.15*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBlock Text="Vehicle Reports"
                       VerticalAlignment="Bottom"
                       FontSize="25"></TextBlock>
                </Grid>

                <Grid Grid.Column="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.015*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!--
                    <ComboBox ItemsSource="{Binding Filters}"
                  SelectedItem="{Binding SelectedFilter}"
                  Width="150"
                  HorizontalAlignment="Right"
                  Grid.Column="1"
                  Grid.Row="1"/>
                -->
                </Grid>


                <Grid Grid.Column="2">

                    <TextBox Margin="10,20,0,0">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost"/>

                                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#f5c3c3"
                                                     FontSize="18"
                                                     HorizontalContentAlignment="Left"
                                                     VerticalContentAlignment="Center"
                                                     Padding="10,0,0,0"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                </Grid>
            </Grid>

            <Grid Grid.Row="1" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="49*"/>
                    <ColumnDefinition Width="10*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="0.015*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.015*"/>
                </Grid.RowDefinitions>

                <ListView ItemsSource="{Binding VehicleReports }"
                  
                    SelectedItem="{Binding SelectedVehicleReport, Mode=TwoWay}"
                     Background="#f5c3c3"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch" Grid.ColumnSpan="2" Margin="0,5,0,5" Grid.RowSpan="3">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="#f5c3c3"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Background="#f5c3c3">
                                <StackPanel>

                                    <TextBlock Foreground="Black"
                                      FontSize="20" FontWeight="Bold"
                                     Text="{Binding VReportId, StringFormat=Report Id: {0}}"  >
                                    </TextBlock>
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                      Text="{Binding VehicleId, StringFormat=Vehicle Id: {0}}" />
                                    <TextBlock FontSize="12"
                                        Text="{Binding TimesUsed, StringFormat=Times Used: {0}}" />
                                    <TextBlock FontSize="12"
                                        Text="{Binding TotalMileageGained, StringFormat=Mileage Gained: {0}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.05*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Button Content="Create"
                              x:Name="CreateButton"
                                 FontSize="15"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              BorderThickness="0"
                              FocusVisualStyle="{x:Null}"
                              Command="{Binding CreateCommand}" Grid.Column="1">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="border"
                                         Background="#F5C3C3">

                                        <ContentPresenter HorizontalAlignment ="Center"
                                        VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border"
                                                 Property="Background"
                                                 Value="#D3D3D3"/>
                                            <Setter Property="Foreground"
                                                Value="#888888"/>
                                            <Setter TargetName="border"
                                                 Property="Opacity"
                                                 Value="0.6"/>
                                        </Trigger>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                                 Property="Background"
                                                 Value="#EDB2B2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                 Property="Background"
                                                 Value="#E6A8A8"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Grid>

                    <Grid Grid.Column="2">

                    </Grid>

                </Grid>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.15*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.05*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.7*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="0.15*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusMessageBrush}"
                       FontWeight="Bold"
                       FontSize="16"
                       VerticalAlignment="Center"/>

                    </Grid>

                    <Button Content="Update"
                         x:Name="EditButton"
                            FontSize="15"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         BorderThickness="0"
                         FocusVisualStyle="{x:Null}"
                        IsEnabled="{Binding SelectedVehicleReport, Converter={StaticResource NullToBoolConverter}}"
                         Command="{Binding UpdateCommand}" Grid.Column="1">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                   Background="#F5C3C3">

                                    <ContentPresenter HorizontalAlignment ="Center"
                                     VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border"
                                            Property="Background"
                                            Value="#D3D3D3"/>
                                        <Setter Property="Foreground"
                                         Value="#888888"/>
                                        <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.6"/>
                                    </Trigger>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                            Property="Background"
                                            Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                            Property="Background"
                                            Value="#E6A8A8"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>

            </Grid>

        </Grid>



    </Grid>
</Page>
