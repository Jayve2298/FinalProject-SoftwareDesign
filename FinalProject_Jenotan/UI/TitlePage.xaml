<Page x:Class="FinalProject_Jenotan.UI.TitlePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FinalProject_Jenotan.UI"
      xmlns:cmd="clr-namespace:FinalProject_Jenotan.Commands"
      mc:Ignorable="d"
      Title="TitlePage" Background="#f5c3c3" d:DesignWidth="1550.252" d:DesignHeight="835.918" >

    <Page.Resources>
        <cmd:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Page.InputBindings>
         <KeyBinding Key="Enter" Command="{Binding LoginCommand}" />
    </Page.InputBindings>



    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.05*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="0.05*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.05*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="0.25*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Column="1" Grid.Row="1" Background="#f9dcdc">



            <MediaElement Source="Designs/TitleVideo.mp4"
                  LoadedBehavior="Manual"
                  IsMuted="True"
                  Stretch="UniformToFill"
                  MediaEnded="TitleVideo_MediaEnded"
                  x:Name="TitleVideo"/>

            <Image Source="pack://application:,,,/Designs/Title01.png"
           Stretch="UniformToFill"/>

        </Grid>

        <Grid Grid.Column="3" Grid.Row="1" Background="#f9dcdc">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="0.05*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0.05*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.15*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.25*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1.5*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                
                
            </Grid>

            <Grid Grid.Column="1" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.15*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="Username" Background="Transparent"
                                   FontSize="20" FontFamily="Times New Roman"/>
                    </Grid>
                    <Grid Grid.Row="2">
                        <TextBox x:Name="UsernameBox" Background="#f5c3c3"
                             BorderThickness="0"
                             Padding="5"
                              Height="30"
                                 VerticalAlignment="Top"
                                 FontSize="15"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="Password" Background="Transparent"
                   FontSize="20" FontFamily="Times New Roman"/>
                    </Grid>
                    <Grid Grid.Row="2">
                        <PasswordBox x:Name="PasswordBox" Background="#f5c3c3"
                             BorderThickness="0"
                                 Padding="5"
                                  Height="30"
                                   VerticalAlignment="Top"
                                     FontSize="15"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                    </Grid>

                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.15*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.75*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Incorrect Credentials"
                                Foreground="Red"
                                FontSize="15"
                                HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                Visibility="{Binding IsLoginInvalid, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    </Grid>


                    <Grid Grid.Row="0" Grid.Column="2">
                        <Button Content="Login"
                              x:Name="LogInButton"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                              BorderThickness="0"
                             FocusVisualStyle="{x:Null}"
                               Command="{Binding LoginCommand}">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="border"
                                          Background="#F5C3C3">

                                        <ContentPresenter HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                                   Property="Background"
                                                    Value="#EDB2B2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                       Value="#E6A8A8"/>
                                        </Trigger>

                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="border"
                                                  Property="BorderThickness"
                                                     Value="0"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Grid>
                    
                   

                </Grid>
                
            </Grid>
            

        </Grid>
    </Grid>


</Page>
