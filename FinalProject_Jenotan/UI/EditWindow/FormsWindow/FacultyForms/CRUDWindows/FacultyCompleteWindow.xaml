<Window x:Class="FinalProject_Jenotan.UI.EditWindow.FormsWindow.FacultyForms.CRUDWindows.FacultyCompleteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalProject_Jenotan.UI.EditWindow.FormsWindow.FacultyForms.CRUDWindows"
        mc:Ignorable="d"
        Title="Completion Form" Height="450" Width="600"    Background="#f5c3c3"
            ResizeMode="NoResize"
            WindowStartupLocation="CenterOwner"
            xmlns:cmd="clr-namespace:FinalProject_Jenotan.Commands"
            xmlns:converters="clr-namespace:FinalProject_Jenotan.Commands">

    <Window.Resources>
        <cmd:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatussColorConverter"/>
        <converters:FacultyNameInitialConverter x:Key="FacultyNameInitialConverter"/>
        <converters:FacultyFullNameConverter x:Key="FacultyFullNameConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.05*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="0.05*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="0.05*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="0.05*"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Column="1" Grid.Row="1" Background="#f9dcdc">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="CForm Id:" FontSize="20"
                        VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                          x:Name="FormIdBox"
                         Background="#edb2b2"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                          Text="{Binding CFormId}"
                           IsReadOnly="True"
                             FontWeight="SemiBold"/>

                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Vehicle Id:" FontSize="20"
                         VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                          x:Name="CourseNameBox"
                         Background="#edb2b2"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                          Text="{Binding VehicleId}"
                           IsReadOnly="True"
                             FontWeight="SemiBold"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Checkout Id:" FontSize="20"
                               VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                          x:Name="CheckOutIdBox"
                         Background="#edb2b2"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                          Text="{Binding CheckoutId}"
                           IsReadOnly="True"
                             FontWeight="SemiBold"/>

                </Grid>

                <Grid Grid.Row="1">
                    <TextBlock 
                        Text="{Binding StatusMessage}" 
                        Foreground="{Binding StatusMessageBrush}"
                        FontSize="20"
                        FontWeight="Bold"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
                </Grid>

            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.05*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="2" Grid.Column="0">
                    <Button Content="Confirm"
                      x:Name="ConfirmButton"
                         FontSize="15"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      BorderThickness="0"
                      FocusVisualStyle="{x:Null}"
                      Command="{Binding ConfirmCommand}" Grid.Column="1">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                    Background="#EDB2B2">

                                    <ContentPresenter HorizontalAlignment ="Center"
                                         VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                             Property="Background"
                                            Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                           Property="Background"
                                                 Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                                           Property="BorderThickness"
                                           Value="0"/>
                                    </Trigger>



                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>


                <Grid Grid.Row="2" Grid.Column="2">
                    <Button Content="Cancel"
                          x:Name="CancelButton"
                             FontSize="15"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          BorderThickness="0"
                          FocusVisualStyle="{x:Null}"
                          Command="{Binding CancelCommand}" Grid.Column="1" Click="CancelButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                   Background="#EDB2B2">

                                    <ContentPresenter HorizontalAlignment ="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                             Property="Background"
                                            Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                           Property="Background"
                                                 Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                                           Property="BorderThickness"
                                           Value="0"/>
                                    </Trigger>



                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>

            </Grid>
            
        </Grid>

        <Grid Grid.Column="3" Grid.Row="1" Background="#f9dcdc">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="StartOdo:" FontSize="20"
                         VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                           x:Name="StartOdoBox"
                          Background="#edb2b2"
                          FontSize="15"
                          VerticalContentAlignment="Center"
                           Text="{Binding StartOdo}"
                            IsReadOnly="True"
                             FontWeight="SemiBold"/>

                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="EndOdo:" FontSize="20"
                          VerticalAlignment="Bottom"></TextBlock>

                                <TextBox Grid.Row="1"
                           x:Name="EndOdoBox"
                          Background="#edb2b2"
                          FontSize="15"
                          VerticalContentAlignment="Center"
                           Text="{Binding EndOdo}"
                            />
                </Grid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Complaints:" FontSize="20"
                         VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                        x:Name="ComplaintsBox"
                       Background="#edb2b2"
                       FontSize="15"
                       VerticalContentAlignment="Center"
                        Text="{Binding Complaints}"
                         IsReadOnly="False"/>

                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Fuel Cost:" FontSize="20"
                     VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                        x:Name="FuelCost"
                       Background="#edb2b2"
                       FontSize="15"
                       VerticalContentAlignment="Center"
                        Text="{Binding FuelCost}"
                      />
                </Grid>


            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Credit Card Number:" FontSize="20"
                        VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                         x:Name="CreditCardNumberBox"
                        Background="#edb2b2"
                        FontSize="15"
                        VerticalContentAlignment="Center"
                         Text="{Binding CreditCardNumber}"
                          IsReadOnly="False"/>

                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Trip Cost:" FontSize="20"
                         VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                         x:Name="TripCost"
                        Background="#edb2b2"
                        FontSize="15"
                        VerticalContentAlignment="Center"
                         Text="{Binding TripCost, StringFormat= Php: {0}}"
                         IsReadOnly="True"/>
                </Grid>
            </Grid>

        </Grid>

    </Grid>
</Window>
