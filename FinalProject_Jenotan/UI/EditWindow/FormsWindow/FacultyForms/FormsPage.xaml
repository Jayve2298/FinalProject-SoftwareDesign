<Page x:Class="FinalProject_Jenotan.UI.EditWindow.FormsWindow.FormsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FinalProject_Jenotan.UI.EditWindow.FormsWindow"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FormsPage" Background="#f9dcdc"
      xmlns:cmd="clr-namespace:FinalProject_Jenotan.Commands"
        xmlns:converters="clr-namespace:FinalProject_Jenotan.Commands">

    <Page.Resources>
        <cmd:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatussColorConverter"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:FacultyNameInitialConverter x:Key="FacultyNameInitialConverter"/>
        <converters:FacultyFullNameConverter x:Key="FacultyFullNameConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="0.05*"></RowDefinition>
            <RowDefinition Height="12*"></RowDefinition>
            <RowDefinition Height="0.05*"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.025*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="0.025*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1" Grid.Column="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="0.025*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="0.025*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="0.025*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="0.025*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">

                <Button Content="Reservation"
                    x:Name="ReservationButton"
                       FontSize="15"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding ReservationCommand}" Grid.Column="1">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="border"
                                Background="#EDB2B2">

                                <ContentPresenter HorizontalAlignment ="Center"
                              VerticalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border"
                                       Property="Background"
                                      Value="#EDB2B2"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border"
                                         Property="Background"
                                               Value="#E6A8A8"/>
                                </Trigger>

                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border"
                                         Property="BorderThickness"
                                         Value="0"/>
                                </Trigger>



                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>

                </Button>

                

            </Grid>

            <Grid Grid.Column="2">
                <Button Content="CheckOut"
                     x:Name="AddButton"
                        FontSize="15"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     BorderThickness="0"
                     FocusVisualStyle="{x:Null}"
                     Command="{Binding CheckOutCommand}" Grid.Column="1">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="border"
                              Background="#EDB2B2">

                                <ContentPresenter HorizontalAlignment ="Center"
                                VerticalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border"
                                        Property="Background"
                                       Value="#EDB2B2"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border"
                                          Property="Background"
                                                Value="#E6A8A8"/>
                                </Trigger>

                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border"
                                      Property="BorderThickness"
                                      Value="0"/>
                                </Trigger>



                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>

                </Button>
            </Grid>

            <Grid Grid.Column="6">
               
                <Button Content="Completed"
                     x:Name="CompletionButton"
                        FontSize="15"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     BorderThickness="0"
                     FocusVisualStyle="{x:Null}"
                     Command="{Binding CompletionCommand}" Grid.Column="1">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="border"
                                  Background="#EDB2B2">

                                <ContentPresenter HorizontalAlignment ="Center"
                              VerticalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border"
                                            Property="Background"
                                           Value="#EDB2B2"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border"
                                          Property="Background"
                                                Value="#E6A8A8"/>
                                </Trigger>

                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border"
                                          Property="BorderThickness"
                                          Value="0"/>
                                </Trigger>



                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>

                </Button>
                
            </Grid>

            <Grid Grid.Column="4">
                <Button Content="OnGoing"
                    x:Name="OnGoingButton"
                    FontSize="15"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding OnGoingCommand}" Grid.Column="1">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="border"
                                  Background="#EDB2B2">

                                <ContentPresenter HorizontalAlignment ="Center"
                                 VerticalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border"
                                       Property="Background"
                                      Value="#EDB2B2"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border"
                                         Property="Background"
                                               Value="#E6A8A8"/>
                                </Trigger>

                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border"
                                         Property="BorderThickness"
                                         Value="0"/>
                                </Trigger>



                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </Grid>
        </Grid>

        <Grid Grid.Row="3" Grid.Column="1">

            <Frame x:Name="FormsMainFrameControl"
                    NavigationUIVisibility="Hidden"/>
        </Grid>
        
    </Grid>
</Page>
