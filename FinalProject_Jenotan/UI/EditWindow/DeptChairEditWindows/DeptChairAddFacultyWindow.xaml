<Window x:Class="FinalProject_Jenotan.UI.EditWindow.DeptChairEditWindows.DeptChairAddFacultyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalProject_Jenotan.UI.EditWindow.DeptChairEditWindows"
        mc:Ignorable="d"
        Title="Add Faculty" Height="450" Width="300"
        Background="#f5c3c3"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        xmlns:cmd="clr-namespace:FinalProject_Jenotan.Commands"
        xmlns:converters="clr-namespace:FinalProject_Jenotan.Commands">

    <Window.Resources>
        <cmd:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatussColorConverter"/>
        <converters:FacultyNameInitialConverter x:Key="FacultyNameInitialConverter"/>
        <converters:FacultyFullNameConverter x:Key="FacultyFullNameConverter"/>
    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.05*"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
            <ColumnDefinition Width="0.05*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="0.05*"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Grid.Column="1" Background="#f9dcdc">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.05*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.05*"/>

            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="First Name:" FontSize="20"
                 VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                     x:Name="TxtFullName"
                 Background="#edb2b2"
                 FontSize="15"
                 VerticalContentAlignment="Center"
                  Text="{Binding FirstName}"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Last Name:" FontSize="20"
                        VerticalAlignment="Bottom" Grid.ColumnSpan="2"></TextBlock>

                    <TextBox
                        Background="#edb2b2"
                        FontSize="15"
                        VerticalContentAlignment="Center"
                         Text="{Binding LastName}" Grid.ColumnSpan="2" Margin="0,34,0,0" Grid.RowSpan="2"/>
                </Grid>


            </Grid>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Contact Number:" FontSize="20"
                      VerticalAlignment="Bottom"></TextBlock>

                    <TextBox Grid.Row="1"
                        Background="#edb2b2"
                        FontSize="15"
                        VerticalContentAlignment="Center"
                         Text="{Binding ContactNumber}"/>
                </Grid>

                <Grid Grid.Row="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Role:" FontSize="20"
                         VerticalAlignment="Bottom"></TextBlock>
                    <ComboBox ItemsSource="{Binding FacultyRole}"
                      SelectedItem="{Binding SelectedFacultyRole}"
                      Width="245"
                      HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                      Grid.Column="1"
                      Grid.Row="1"/>


                </Grid>
            </Grid>

            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.05*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.15*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="2" Grid.Column="0">
                    <Button Content="Confirm"
                      x:Name="ConfirmButton"
                         FontSize="15"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      BorderThickness="0"
                      FocusVisualStyle="{x:Null}"
                      Command="{Binding ConfirmCommand}" Grid.Column="1">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                 Background="#EDB2B2">

                                    <ContentPresenter HorizontalAlignment ="Center"
                                       VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                         Property="Background"
                                        Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                       Property="Background"
                                             Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                                           Property="BorderThickness"
                                           Value="0"/>
                                    </Trigger>



                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="2">
                    <Button Content="Cancel"
          x:Name="CancelButton"
             FontSize="15"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          BorderThickness="0"
          FocusVisualStyle="{x:Null}"
           Grid.Column="1" Click="CloseWindow">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
             Background="#EDB2B2">

                                    <ContentPresenter HorizontalAlignment ="Center"
              VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                     Property="Background"
                    Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                   Property="Background"
                         Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                       Property="BorderThickness"
                       Value="0"/>
                                    </Trigger>



                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
