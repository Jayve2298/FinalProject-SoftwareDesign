<Window x:Class="FinalProject_Jenotan.UI.EditWindow.DeptChairEditWindows.DeptChairAddClassWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalProject_Jenotan.UI.EditWindow.DeptChairEditWindows"
        mc:Ignorable="d"
        Title="Add Class" Height="450" Width="1000"
        xmlns:cmd="clr-namespace:FinalProject_Jenotan.Commands"
        xmlns:converters="clr-namespace:FinalProject_Jenotan.Commands" xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Background="#f5c3c3"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <cmd:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <converters:BoolToStatusConverter x:Key="BoolToStatussColorConverter"/>
        <converters:FacultyNameInitialConverter x:Key="FacultyNameInitialConverter"/>
    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.05*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.05*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="0.05*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.05*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Grid.Column="3" Background="#f9dcdc">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.015*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.015*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="0.05*"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0.05*"/>
                <RowDefinition Height="9*"/>
                <RowDefinition Height="0.05*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="3" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.015*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.015*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="0.05*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Select Room:" 
                               FontSize="20"
                               VerticalAlignment="Bottom"
                               Grid.Row="1" 
                               Grid.Column="1"></TextBlock>

                    <Grid Grid.Column="1" Grid.Row="3">

                        <!-- LISTVIEW -->
                        <ListView ItemsSource="{Binding Rooms}"
                              SelectedItem="{Binding SelectedRoom, Mode=TwoWay}"
                              IsEnabled="{Binding IsConfirmed}"
                              Background="#f5c3c3"
                              BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              Margin="0,5,0,5">

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="#f5c3c3"/>
                                    <Setter Property="BorderThickness" Value="0"/>

                                    <Style.Triggers>
                                        <!-- SELECTED GLOW -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#db9d9d"
                                          BlurRadius="20"
                                          ShadowDepth="0"
                                          Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>

                                            <!-- optional background highlight -->
                                            <Setter Property="Background" Value="#db9d9d"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <!-- hide scrollbar -->
                            <ListView.Resources>
                                <Style TargetType="{x:Type ScrollBar}">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="Opacity" Value="0"/>
                                </Style>
                            </ListView.Resources>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Background="#f5c3c3">
                                        <StackPanel>

                                            <TextBlock Foreground="Black"
                                   FontSize="15"
                                   Text="{Binding RoomCode}" />

                                            <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding BuildingId, StringFormat=Building Id: {0}}" />

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>

                        </ListView>

                        <!-- OVERLAY TEXT -->
                        <TextBlock Text="Confirm to load"
               FontSize="16"
               Foreground="Gray"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConfirmed}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>

                    </Grid>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.015*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.015*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="0.05*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Select Course:" 
                       FontSize="20"
                       VerticalAlignment="Bottom"
                       Grid.Row="1" 
                       Grid.Column="1"></TextBlock>

                    <Grid Grid.Column="1" Grid.Row="3">
                        <ListView ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse, Mode=TwoWay}" Background="#f5c3c3" BorderThickness="0" HorizontalContentAlignment="Stretch" Grid.ColumnSpan="2" Margin="0,5,0,5" Grid.RowSpan="3">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="#f5c3c3"/>
                                    <Setter Property="BorderThickness" Value="0"/>

                                    <Style.Triggers>
                                        <!-- SELECTED GLOW -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#db9d9d"
                                          BlurRadius="20"
                                          ShadowDepth="0"
                                          Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>

                                            <!-- optional background highlight -->
                                            <Setter Property="Background" Value="#db9d9d"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.Resources>
                                <Style TargetType="{x:Type ScrollBar}">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="Opacity" Value="0"/>
                                </Style>
                            </ListView.Resources>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Background="#f5c3c3">
                                        <StackPanel>

                                            <TextBlock Foreground="Black" FontSize="15" Text="{Binding CourseName}"></TextBlock>
                                            <TextBlock FontSize="10" FontWeight="SemiBold" Text="{Binding CourseId, StringFormat=Course Id: {0}}"/>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.015*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.015*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="0.05*"/>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="0.05*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Select Faculty:" 
                       FontSize="20"
                       VerticalAlignment="Bottom"
                       Grid.Row="1" 
                       Grid.Column="1"></TextBlock>

                    <Grid Grid.Column="1" Grid.Row="3">

                        <!-- LISTVIEW -->
                        <ListView ItemsSource="{Binding Faculties}"
                              SelectedItem="{Binding SelectedFaculty, Mode=TwoWay}"
                              IsEnabled="{Binding IsConfirmed}"
                              Background="#f5c3c3"
                              BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              Margin="0,5,0,5">

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="#f5c3c3"/>
                                    <Setter Property="BorderThickness" Value="0"/>

                                    <Style.Triggers>
                                        <!-- SELECTED GLOW -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#db9d9d"
                                                  BlurRadius="20"
                                                  ShadowDepth="0"
                                                  Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>

                                            <!-- optional background highlight -->
                                            <Setter Property="Background" Value="#db9d9d"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <!-- hide scrollbar -->
                            <ListView.Resources>
                                <Style TargetType="{x:Type ScrollBar}">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="Opacity" Value="0"/>
                                </Style>
                            </ListView.Resources>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Background="#f5c3c3">
                                        <StackPanel>

                                            <TextBlock Foreground="Black"
                                               FontSize="15"
                                               Text="{Binding FacultyId}" />
                                            <TextBlock Foreground="Black"
                                                       FontSize="12"
                                                       Text="{Binding LName, StringFormat= Last Name: {0}}" />

                                            <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="{Binding Role, StringFormat=Role: {0}}" />

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>

                        </ListView>

                        <!-- OVERLAY TEXT -->
                        <TextBlock Text="Confirm to load"
               FontSize="16"
               Foreground="Gray"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConfirmed}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>

                    </Grid>
                </Grid>

            </Grid>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="0.25*"/>

                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1">

                    </Grid>

                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1" Background="#f9dcdc">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.05*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.05*"/>

            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Class Id:" FontSize="20"
                           VerticalAlignment="Bottom"></TextBlock>

                    <TextBox
                         Grid.Row="1" IsReadOnly="True"
                        Text="{Binding ClassId}" VerticalContentAlignment="Center" FontSize="15" FontWeight="SemiBold"></TextBox>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Duration:" FontSize="20"
                         VerticalAlignment="Bottom" Grid.ColumnSpan="2" Margin="0,0,0,33" Grid.RowSpan="2"></TextBlock>

                    <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding Durations}"
                          SelectedItem="{Binding SelectedDuration}"
                          DisplayMemberPath="Label"></ComboBox>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="163*"/>
                        <ColumnDefinition Width="125*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Day:" FontSize="20"
                      VerticalAlignment="Bottom" Grid.ColumnSpan="2" Margin="0,0,0,33" Grid.RowSpan="2"></TextBlock>

                    <ComboBox Grid.Row="1"
                      ItemsSource="{Binding Days}"
                        SelectedItem="{Binding SelectedDay}" Grid.ColumnSpan="2"></ComboBox>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Time Start:" FontSize="20"
                          VerticalAlignment="Bottom" Margin="150,0,0,0"></TextBlock>

                    <xctk:TimePicker 
                        Value="{Binding ClassTime, Mode=TwoWay}" 
                        Format="ShortTime" Grid.Row="1" Margin="150,0,0,0" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <Grid Grid.Row="1">
                        <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Grid>




                </Grid>
            </Grid>

            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.05*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.15*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="2">
                    <Button Content="Confirm"
                        x:Name="confirmButton"
                           FontSize="15"
                        BorderThickness="0"
                        FocusVisualStyle="{x:Null}"
                        Command="{Binding ConfirmDetailsCommand}" Margin="0,10,0,0">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                     Background="#EDB2B2">

                                    <ContentPresenter HorizontalAlignment ="Center"
                                    VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                           Property="Background"
                                          Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                         Property="Background"
                               Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                         Property="BorderThickness"
                         Value="0"/>
                                    </Trigger>



                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="0">
                    <Button Content="Add"
                  x:Name="AddButton"
                     FontSize="15"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  BorderThickness="0"
                  FocusVisualStyle="{x:Null}"
                  Command="{Binding AddCommand}" Grid.Column="1">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                     Background="#EDB2B2">

                                    <ContentPresenter HorizontalAlignment ="Center"
                                      VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                         Property="Background"
                                        Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                       Property="Background"
                                             Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                                           Property="BorderThickness"
                                           Value="0"/>
                                    </Trigger>



                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="2">
                    <Button Content="Cancel"
                  x:Name="CancelButton"
                     FontSize="15"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  BorderThickness="0"
                  FocusVisualStyle="{x:Null}"
                  Command="{Binding CancelCommand}" Grid.Column="1" Click="CancelButton_Click_1">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                 Background="#EDB2B2">

                                    <ContentPresenter HorizontalAlignment ="Center"
                                  VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                         Property="Background"
                                        Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                       Property="Background"
                                             Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                                           Property="BorderThickness"
                                           Value="0"/>
                                    </Trigger>



                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
