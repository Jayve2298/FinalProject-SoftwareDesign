<Page x:Class="FinalProject_Jenotan.UI.DeanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FinalProject_Jenotan.UI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DeanPage" Background="#f5c3c3">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.05*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.05*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="0.05*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.05*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Column="3" Grid.Row="1">
            <Frame x:Name="DeanMainFrameControl"
          NavigationUIVisibility="Hidden"/>
        </Grid>



        <Grid Grid.Row="1" Grid.Column="1" Background="#f9dcdc">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.15*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.15*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="0.15*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Button Content="Departments"
                                       x:Name="DepartmentsButton"
                                  HorizontalAlignment="Stretch"
                                FontSize="15"
                                  VerticalAlignment="Stretch"
                                     BorderThickness="0"
                                     FocusVisualStyle="{x:Null}"
                                   Command="{Binding OpenDepartmentsCommand}" Grid.Column="1">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="border"
                                          Background="#F5C3C3">

                                        <ContentPresenter HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                                          />

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                              <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#EDB2B2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                Property="Background"
                                                       Value="#E6A8A8"/>
                                        </Trigger>

                                        <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="border"
                                                    Property="BorderThickness"
                                                Value="0"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Grid>
                    <Grid Grid.Row="3" Grid.Column="1">
                        <Button Content="Faculties"
                          x:Name="FacutliesButton"
                                FontSize="15"
                          HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                              BorderThickness="0"
                               FocusVisualStyle="{x:Null}"
                             Command="{Binding OpenFacultiesCommand}" Grid.Column="1">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="border"
                                          Background="#F5C3C3">

                                        <ContentPresenter HorizontalAlignment="Left"
                                        VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                             <Setter TargetName="border"
                                                  Property="Background"
                                              Value="#EDB2B2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                   Property="Background"
                                                   Value="#E6A8A8"/>
                                        </Trigger>

                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="border"
                                                  Property="BorderThickness"
                                                  Value="0"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Grid>
                    
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.15*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.15*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="0.15*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Button Content="Class"
                    x:Name="ClassButton"
               HorizontalAlignment="Stretch"
                                FontSize="15"
               VerticalAlignment="Stretch"
                  BorderThickness="0"
                  FocusVisualStyle="{x:Null}"
                Command="{Binding ClassesCommand}" Grid.Column="1">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="border"
                       Background="#F5C3C3">

                                        <ContentPresenter HorizontalAlignment="Left"
                         VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                 Property="Background"
                                 Value="#EDB2B2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                             Property="Background"
                                    Value="#E6A8A8"/>
                                        </Trigger>

                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="border"
                                 Property="BorderThickness"
                             Value="0"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Grid>
                    <Grid Grid.Row="3" Grid.Column="1">
                        <Button Content="Trip Forms"
                             x:Name="TripFormButton"
                                FontSize="15"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             BorderThickness="0"
                             FocusVisualStyle="{x:Null}"
                             Command="{Binding FormsCommand}" Grid.Column="1">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="border"
                                          Background="#F5C3C3">

                                        <ContentPresenter HorizontalAlignment="Left"
                                             VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                                Property="Background"
                                               Value="#EDB2B2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                              Property="Background"
                                                    Value="#E6A8A8"/>
                                        </Trigger>

                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="border"
                                              Property="BorderThickness"
                                              Value="0"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Grid>
                    
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.15*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.15*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="0.15*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!--
                    <Button Content="Advisory"
                         x:Name="AdvisoryButton"
                            FontSize="15"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         BorderThickness="0"
                         FocusVisualStyle="{x:Null}"
                         Command="{Binding AdvisoryCommand}" Grid.Column="1" Grid.Row="1">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                  Background="#F5C3C3">

                                    <ContentPresenter HorizontalAlignment="Left"
                                    VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                        Property="Background"
                                       Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                          Property="Background"
                                                Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                                          Property="BorderThickness"
                                          Value="0"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                    -->

                </Grid>
                
                
            </Grid>

            <Border Grid.Row="0"
            CornerRadius="15"
            Background="White"
            Padding="15"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="0.05*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Image
                        Source="/Designs/Basic pfp.jpg" Margin="14,2,3,2"/>
                </Grid>

                <Grid Grid.Column="2">
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding FullName}" FontSize="25" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Role}" FontSize="18"/>
                        <TextBlock Text="{Binding SchoolName, StringFormat=School of {0}}" 
                             FontSize="14"/>
                        <TextBlock Text="{Binding DepartmentName}" FontSize="14"/>

                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.05*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Column="0" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.05*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="LogOut"
                        x:Name="LogInButton"
                        HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                            BorderThickness="0"
                               FocusVisualStyle="{x:Null}"
                              Command="{Binding LogoutCommand}" Grid.Column="1">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                     Background="#F5C3C3">

                                    <ContentPresenter HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                             Property="Background"
                                             Value="#EDB2B2"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                            Property="Background"
                                             Value="#E6A8A8"/>
                                    </Trigger>

                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border"
                                             Property="BorderThickness"
                                              Value="0"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>


            </Grid>

        </Grid>


    </Grid>
</Page>
